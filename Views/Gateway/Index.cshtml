@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ยินดีต้อนรับ - ชาติชายฟาร์ม</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    
    <style>
        :root {
            --primary-green: #1d976c;
            --dark-green: #1a2a23;
            --accent-green: #93f9b9;
        }

        body {
            font-family: 'Sarabun', sans-serif;
            background: radial-gradient(circle at top right, #f0fdf4, #dcfce7);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow-x: hidden;
        }

        /* ตกแต่งพื้นหลังด้วยวงกลมจางๆ */
        body::before {
            content: "";
            position: absolute;
            width: 400px;
            height: 400px;
            background: var(--accent-green);
            filter: blur(100px);
            border-radius: 50%;
            top: -100px;
            left: -100px;
            opacity: 0.3;
            z-index: -1;
        }

        .choice-card {
            border-radius: 24px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 1px solid rgba(255,255,255,0.8);
            overflow: hidden;
            text-decoration: none;
            color: inherit;
            display: flex;
            flex-direction: column;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
        }

        .choice-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 25px 50px rgba(0,0,0,0.1);
            border-color: var(--primary-green);
        }

        .icon-wrapper {
            height: 180px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 5rem;
            transition: all 0.3s ease;
        }

        .choice-card:hover .icon-wrapper {
            font-size: 5.5rem;
        }

        .btn-custom {
            border-radius: 15px;
            padding: 12px 20px;
            font-weight: 700;
            transition: all 0.3s ease;
        }

        .card-customer {
            border-bottom: 6px solid var(--primary-green);
        }

        .card-staff {
            border-bottom: 6px solid var(--dark-green);
        }

        .gradient-text {
            background: linear-gradient(90deg, var(--dark-green), var(--primary-green));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body>
    <div class="container py-5">
        <div class="text-center mb-5 animate__animated animate__fadeInDown">
            <h1 class="fw-bold gradient-text display-5">ชาติชายฟาร์ม</h1>
            <p class="text-muted fs-5">ยินดีต้อนรับสู่ระบบจัดการร้านปุ๋ยครบวงจร</p>
        </div>

        <div class="row justify-content-center g-4">
            
            <!-- ทางเลือก: ลูกค้า -->
            <div class="col-md-5 col-lg-4 animate__animated animate__fadeInLeft animate__delay-1s">
                <a href="@Url.Action("Index", "Home")" class="card choice-card shadow-sm h-100 card-customer">
                    <div class="icon-wrapper bg-success-subtle text-success">
                        <i class="bi bi-shop-window"></i>
                    </div>
                    <div class="card-body text-center p-4">
                        <h4 class="fw-bold text-dark mb-3">หน้าร้านค้าออนไลน์</h4>
                        <p class="text-muted small mb-4">สำหรับลูกค้า: เลือกซื้อสินค้า, ดูโปรโมชั่นสะสมแต้ม และตรวจสอบสถานะสินค้า</p>
                        <span class="btn btn-success btn-custom w-100 shadow-sm">
                            เข้าสู่หน้าร้านค้า <i class="bi bi-arrow-right ms-2"></i>
                        </span>
                    </div>
                </a>
            </div>

            <!-- ทางเลือก: พนักงาน -->
            <div class="col-md-5 col-lg-4 animate__animated animate__fadeInRight animate__delay-1s">
                <a href="@Url.Action("Login", "Account")" class="card choice-card shadow-sm h-100 card-staff">
                    <div class="icon-wrapper text-white" style="background: linear-gradient(135deg, #1a2a23 0%, #2f3e46 100%);">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <div class="card-body text-center p-4">
                        <h4 class="fw-bold text-dark mb-3">ระบบหลังบ้าน</h4>
                        <p class="text-muted small mb-4">สำหรับพนักงาน: จัดการสต็อกสินค้า, ระบบขาย POS, และรายงานสรุปยอดขาย</p>
                        <span class="btn btn-dark btn-custom w-100 shadow-sm">
                            ลงชื่อเข้าทำงาน <i class="bi bi-key-fill ms-2"></i>
                        </span>
                    </div>
                </a>
            </div>

        </div>

        @* <div class="text-center mt-5 animate__animated animate__fadeInUp animate__delay-2s">
            <p class="text-muted small">&copy; 2026 Chartchai Farm Management System. All Rights Reserved.</p>
        </div> *@
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>