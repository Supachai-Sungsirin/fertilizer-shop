@model IEnumerable<FertilizerShop.Models.Product>
@{
    ViewData["Title"] = "ระบบขายหน้าร้าน (POS)";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { background-color: #f0f2f5; overflow: hidden; } /* ซ่อน Scrollbar ของหน้าหลัก */
        .pos-header { background-color: #2f3e46; color: white; padding: 10px 20px; }
        .product-area { height: calc(100vh - 60px); overflow-y: auto; padding: 20px; }
        .cart-area { height: calc(100vh - 60px); background: white; border-left: 2px solid #dee2e6; display: flex; flex-direction: column; }
        .cart-items { flex-grow: 1; overflow-y: auto; padding: 15px; }
        .cart-summary { background: #e9ecef; padding: 20px; border-top: 2px solid #dee2e6; }
        .product-card { cursor: pointer; transition: transform 0.1s; }
        .product-card:hover { transform: scale(1.02); border-color: #198754; }
        .product-image-placeholder { height: 120px; background-color: #e9ecef; display: flex; align-items: center; justify-content: center; font-size: 2rem; color: #adb5bd; }
    </style>
</head>
<body>

    <div class="pos-header d-flex justify-content-between align-items-center">
        <h4 class="m-0"><i class="bi bi-shop"></i> ระบบแคชเชียร์</h4>
        <div>
            <span class="me-3"><i class="bi bi-person-circle"></i> พนักงาน: @User.Identity.Name</span>
            <a href="@Url.Action("Logout", "Account")" class="btn btn-sm btn-danger"><i class="bi bi-box-arrow-right"></i> ออกจากระบบ</a>
        </div>
    </div>

    <div class="container-fluid p-0">
        <div class="row g-0">
            <div class="col-md-8 product-area">
                
                <div class="mb-3">
                    <button class="btn btn-outline-success active me-1 mb-1">ทั้งหมด</button>
                    @foreach (var cat in ViewBag.Categories as IEnumerable<FertilizerShop.Models.Category>)
                    {
                        <button class="btn btn-outline-secondary me-1 mb-1">@cat.CategoryName</button>
                    }
                </div>

                <div class="row g-3">
                    @foreach (var p in Model)
                    {
                        <div class="col-md-3 col-sm-4">
                            <div class="card product-card h-100 shadow-sm" 
                                 onclick="addToCart(@p.ProductId, '@p.Name', @p.Price, @p.StockQuantity)">
                                <div class="product-image-placeholder">
                                    <i class="bi bi-box-seam"></i>
                                </div>
                                <div class="card-body p-2 text-center">
                                    <h6 class="card-title text-truncate mb-1" title="@p.Name">@p.Name</h6>
                                    <small class="text-muted d-block mb-1">คงเหลือ: @p.StockQuantity</small>
                                    <h5 class="text-success mb-0 fw-bold">฿@p.Price.ToString("N2")</h5>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="col-md-4 cart-area">
                <div class="p-3 bg-light border-bottom fw-bold text-center fs-5">
                    <i class="bi bi-cart3"></i> รายการสั่งซื้อ
                </div>
                
                <div class="cart-items" id="cart-items-container">
                    <div class="text-center text-muted mt-5">
                        <i class="bi bi-basket fs-1"></i><br />ยังไม่มีสินค้าในตะกร้า
                    </div>
                </div>

                <div class="cart-summary">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="fs-5">ยอดรวมทั้งหมด</span>
                        <span class="fs-4 fw-bold text-danger" id="total-price">฿ 0.00</span>
                    </div>
                    <button class="btn btn-success w-100 py-3 fs-5 fw-bold shadow" onclick="checkout()" id="btn-checkout" disabled>
                        ชำระเงิน <i class="bi bi-arrow-right-circle"></i>
                    </button>
                    <button class="btn btn-outline-danger w-100 mt-2" onclick="clearCart()">
                        ยกเลิกบิล
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // สร้าง Array เก็บรายการสินค้าในตะกร้า
        let cart = [];

        // ฟังก์ชันเพิ่มสินค้าลงตะกร้า
        function addToCart(id, name, price, maxStock) {
            // เช็คว่ามีสินค้านี้ในตะกร้าหรือยัง
            let existingItem = cart.find(item => item.id === id);
            
            if (existingItem) {
                // ถ้ามีแล้วและจำนวนยังไม่เกินสต็อก ให้บวกเพิ่ม 1
                if (existingItem.qty < maxStock) {
                    existingItem.qty++;
                } else {
                    alert("สินค้าในสต็อกไม่เพียงพอ!");
                }
            } else {
                // ถ้ายังไม่มี ให้เพิ่มเข้าไปใหม่
                cart.push({ id: id, name: name, price: price, qty: 1, maxStock: maxStock });
            }
            renderCart();
        }

        // ฟังก์ชันลบ/ลด จำนวนสินค้า
        function changeQty(id, amount) {
            let itemIndex = cart.findIndex(item => item.id === id);
            if (itemIndex > -1) {
                cart[itemIndex].qty += amount;
                
                // ถ้าจำนวนเหลือ 0 หรือน้อยกว่า ให้ลบออกจากตะกร้า
                if (cart[itemIndex].qty <= 0) {
                    cart.splice(itemIndex, 1);
                } else if (cart[itemIndex].qty > cart[itemIndex].maxStock) {
                    cart[itemIndex].qty = cart[itemIndex].maxStock;
                    alert("สินค้าในสต็อกไม่เพียงพอ!");
                }
                renderCart();
            }
        }

        // ฟังก์ชันล้างตะกร้า
        function clearCart() {
            if(cart.length > 0 && confirm("ต้องการยกเลิกบิลนี้ใช่หรือไม่?")) {
                cart = [];
                renderCart();
            }
        }

        // ฟังก์ชันวาด UI ตะกร้าใหม่ทุกครั้งที่มีการเปลี่ยนแปลง
        function renderCart() {
            let container = document.getElementById("cart-items-container");
            let totalElement = document.getElementById("total-price");
            let btnCheckout = document.getElementById("btn-checkout");
            
            if (cart.length === 0) {
                container.innerHTML = `<div class="text-center text-muted mt-5"><i class="bi bi-basket fs-1"></i><br />ยังไม่มีสินค้าในตะกร้า</div>`;
                totalElement.innerText = "฿ 0.00";
                btnCheckout.disabled = true;
                return;
            }

            let html = "";
            let total = 0;

            cart.forEach(item => {
                let itemTotal = item.price * item.qty;
                total += itemTotal;
                
                html += `
                <div class="card mb-2 border-0 shadow-sm">
                    <div class="card-body p-2 d-flex justify-content-between align-items-center">
                        <div style="width: 50%;">
                            <div class="fw-bold text-truncate" style="font-size: 0.9rem;" title="${item.name}">${item.name}</div>
                            <div class="text-muted small">฿${item.price.toFixed(2)}</div>
                        </div>
                        <div class="d-flex align-items-center">
                            <button class="btn btn-sm btn-outline-secondary px-2 py-0" onclick="changeQty(${item.id}, -1)">-</button>
                            <span class="mx-2 fw-bold">${item.qty}</span>
                            <button class="btn btn-sm btn-outline-secondary px-2 py-0" onclick="changeQty(${item.id}, 1)">+</button>
                        </div>
                        <div class="fw-bold text-end" style="width: 25%;">
                            ฿${itemTotal.toFixed(2)}
                        </div>
                    </div>
                </div>`;
            });

            container.innerHTML = html;
            totalElement.innerText = "฿ " + total.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
            btnCheckout.disabled = false;
        }

        // ฟังก์ชันสำหรับกดปุ่มชำระเงิน
        function checkout() {
            if (cart.length === 0) return;

            // ถามยืนยันก่อนคิดเงิน
            let totalText = document.getElementById("total-price").innerText;
            if (confirm("ยืนยันการชำระเงินยอดรวม " + totalText + " ใช่หรือไม่?")) {
                
                // เปลี่ยนสถานะปุ่มเป็นกำลังโหลด ป้องกันการกดซ้ำ
                let btn = document.getElementById("btn-checkout");
                btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> กำลังประมวลผล...';
                btn.disabled = true;

                // ส่งข้อมูลตะกร้า (cart) ไปที่ Controller ด้วย Fetch API
                fetch('/Cashier/Checkout', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json' // บอกเซิร์ฟเวอร์ว่าส่งไปเป็น JSON
                    },
                    body: JSON.stringify(cart) // แปลง Array เป็น JSON
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert("บันทึกการขายสำเร็จ! รหัสบิล: ORD-" + data.orderId);
                        cart = []; // ล้างตะกร้า
                        renderCart(); // วาด UI ตะกร้าใหม่
                        location.reload(); // รีเฟรชหน้าเว็บ เพื่อให้สต็อกสินค้าฝั่งซ้ายอัปเดตตัวเลขล่าสุด
                    } else {
                        alert("เกิดข้อผิดพลาด: " + data.message);
                        resetButton();
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert("เกิดข้อผิดพลาดในการเชื่อมต่อกับเซิร์ฟเวอร์");
                    resetButton();
                });

                // ฟังก์ชันย่อยสำหรับคืนค่าปุ่มเดิมเวลามี Error
                function resetButton() {
                    btn.innerHTML = 'ชำระเงิน <i class="bi bi-arrow-right-circle"></i>';
                    btn.disabled = false;
                }
            }
        }
    </script>
</body>
</html>