@model FertilizerShop.ViewModels.CustomerRegisterViewModel
@{
    ViewData["Title"] = "สมัครสมาชิกใหม่";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .register-card {
        border-radius: 20px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05) !important;
    }

    .register-header {
        background: linear-gradient(135deg, #1d976c 0%, #1a2a23 100%);
        padding: 40px 20px;
        color: white;
        border: none;
    }

    .form-floating > .form-control {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
    }

    .form-floating > .form-control:focus {
        border-color: #1d976c;
        box-shadow: 0 0 0 4px rgba(29, 151, 108, 0.1);
    }

    .btn-register {
        background: linear-gradient(45deg, #1d976c, #167a57);
        border: none;
        border-radius: 50px;
        padding: 12px;
        font-weight: 700;
        transition: all 0.3s;
    }

    .btn-register:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(29, 151, 108, 0.3);
        color: white;
    }

    .login-link {
        color: #1d976c;
        font-weight: 700;
        text-decoration: none;
        position: relative;
    }

    .login-link:hover {
        text-decoration: underline;
    }

    .input-group-text-custom {
        background-color: transparent;
        border: none;
        color: #1d976c;
    }
</style>

<div class="container mt-5 mb-5 animate__animated animate__fadeIn">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            
            <div class="card register-card border-0">
                <div class="register-header text-center">
                    <h3 class="fw-bold mb-1">สมัครสมาชิกใหม่</h3>
                    <p class="small mb-0 opacity-75">ร่วมเป็นส่วนหนึ่งกับชาติชายฟาร์มเพื่อสิทธิพิเศษมากมาย</p>
                </div>

                <div class="card-body p-4 p-sm-5">
                    <form asp-action="Register" method="post">
                        
                        <div class="mb-4 text-center">
                            <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill small">
                                <i class="bi bi-gift-fill me-1"></i> สมัครวันนี้ รับแต้มสะสมทันทีเมื่อซื้อสินค้า
                            </span>
                        </div>

                        <!-- เบอร์โทรศัพท์ -->
                        <div class="form-floating mb-3">
                            <input asp-for="Phone" class="form-control" placeholder="08xxxxxxxx" maxlength="10" />
                            <label asp-for="Phone" class="text-muted">
                                <i class="bi bi-telephone me-1"></i> เบอร์โทรศัพท์ (ใช้เป็นไอดีเข้าสู่ระบบ)
                            </label>
                            <span asp-validation-for="Phone" class="text-danger small ms-2"></span>
                        </div>

                        <!-- ชื่อ-นามสกุล -->
                        <div class="form-floating mb-3">
                            <input asp-for="FullName" class="form-control" placeholder="ชื่อ-นามสกุล" />
                            <label asp-for="FullName" class="text-muted">
                                <i class="bi bi-person-bounding-box me-1"></i> ชื่อ - นามสกุล
                            </label>
                            <span asp-validation-for="FullName" class="text-danger small ms-2"></span>
                        </div>

                        <!-- รหัสผ่าน -->
                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <div class="form-floating">
                                    <input asp-for="Password" type="password" class="form-control" placeholder="รหัสผ่าน" />
                                    <label asp-for="Password" class="text-muted">
                                        <i class="bi bi-shield-lock me-1"></i> รหัสผ่าน
                                    </label>
                                    <span asp-validation-for="Password" class="text-danger small ms-2"></span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-floating">
                                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="ยืนยันรหัสผ่าน" />
                                    <label asp-for="ConfirmPassword" class="text-muted">
                                        <i class="bi bi-shield-check me-1"></i> ยืนยันรหัสผ่าน
                                    </label>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small ms-2"></span>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100 btn-register shadow-sm mb-4">
                            <i class="bi bi-check-circle-fill me-1"></i> ยืนยันการสมัครสมาชิก
                        </button>
                    </form>

                    <hr class="opacity-10 mb-4">

                    <div class="text-center">
                        <p class="text-muted small mb-1">เป็นสมาชิกอยู่แล้วใช่ไหม?</p> 
                        <a href="@Url.Action("Login", "CustomerAuth")" class="login-link">
                            เข้าสู่ระบบที่นี่ <i class="bi bi-arrow-right-short"></i>
                        </a>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4 mb-5">
                <a href="@Url.Action("Index", "Home")" class="text-muted small text-decoration-none">
                    <i class="bi bi-chevron-left"></i> กลับไปหน้าหลัก
                </a>
            </div>
        </div>
    </div>
</div>
