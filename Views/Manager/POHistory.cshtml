@model IEnumerable<FertilizerShop.Models.Purchaseorder>
@{
    ViewData["Title"] = "ประวัติใบสั่งซื้อ (PO)";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-journal-text"></i> ประวัติใบสั่งซื้อสินค้า (PO)</h2>
    <a href="@Url.Action("CreatePO", "Manager")" class="btn btn-success"><i class="bi bi-plus-circle"></i> สร้างใบสั่งซื้อใหม่</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>เลขที่ PO</th>
                    <th>วันที่สั่งซื้อ</th>
                    <th>ผู้จัดจำหน่าย (Supplier)</th>
                    <th class="text-end">ยอดรวมต้นทุน</th>
                    <th class="text-center">สถานะ</th>
                    <th class="text-center">จัดการ</th>
                </tr>
            </thead>
            <tbody>
                @if(Model.Any()) {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">PO-@item.PoId.ToString("D4")</td>
                            <td>@item.OrderDate.Value.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.Supplier?.Name</td>
                            <td class="text-end fw-bold text-danger">฿ @item.TotalAmount.ToString("N2")</td>
                            <td class="text-center">
                                @if (item.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> รอรับสินค้า</span>
                                }
                                else if (item.Status == "Received")
                                {
                                    <span class="badge bg-success"><i class="bi bi-check2-all"></i> รับสินค้าแล้ว</span>
                                }
                            </td>
                            <td class="text-center">
                                <a href="@Url.Action("PODetails", "Manager", new { id = item.PoId })" class="btn btn-sm btn-primary">
                                    <i class="bi bi-search"></i> เปิดดู
                                </a>
                            </td>
                        </tr>
                    }
                } else {
                    <tr><td colspan="6" class="text-center py-4">ยังไม่มีประวัติการสั่งซื้อ</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>