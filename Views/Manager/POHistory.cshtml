@model IEnumerable<FertilizerShop.Models.Purchaseorder>
@{
    ViewData["Title"] = "ประวัติใบสั่งซื้อ (PO)";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .po-table thead th {
        background-color: #f8fafc;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
        font-weight: 700;
        color: #475569;
        padding: 15px;
        border: none;
    }

    .po-table tbody td {
        padding: 18px 15px;
        border-bottom: 1px solid #f1f5f9;
    }

    .po-id-tag {
        font-family: 'Inter', sans-serif;
        background-color: #e2e8f0;
        color: #1e293b;
        padding: 4px 10px;
        border-radius: 6px;
        font-weight: 700;
        font-size: 0.85rem;
    }

    .amount-text {
        font-family: 'Inter', sans-serif;
        color: #dc3545;
        font-weight: 700;
        font-size: 1rem;
    }

    .status-badge {
        padding: 6px 12px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.8rem;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .btn-view-po {
        border-radius: 10px;
        padding: 6px 16px;
        font-weight: 600;
        transition: all 0.2s;
    }

    .btn-view-po:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 6px rgba(13, 110, 253, 0.15);
    }

    .empty-state {
        padding: 50px 0;
        text-align: center;
        color: #94a3b8;
    }
</style>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-journal-text text-success me-2"></i> ประวัติใบสั่งซื้อสินค้า (PO)</h2>
        <p class="text-muted small mb-0">ติดตามและจัดการรายการสั่งซื้อสินค้าจาก Supplier เข้าสู่คลังสินค้า</p>
    </div>
    <a href="@Url.Action("CreatePO", "Manager")" class="btn btn-success shadow-sm px-4 py-2" style="border-radius: 12px;">
        <i class="bi bi-plus-circle-fill me-2"></i> สร้างใบสั่งซื้อใหม่
    </a>
</div>

<div class="card shadow-sm border-0" style="border-radius: 20px; overflow: hidden;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 po-table">
                <thead>
                    <tr>
                        <th class="ps-4">เลขที่ PO</th>
                        <th>วันที่สั่งซื้อ</th>
                        <th>ผู้จัดจำหน่าย (Supplier)</th>
                        <th class="text-end">ยอดรวมต้นทุน</th>
                        <th class="text-center">สถานะ</th>
                        <th class="text-center pe-4">จัดการ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="po-id-tag">PO-@item.PoId.ToString("D4")</span>
                                </td>
                                <td>
                                    <div class="small fw-bold text-dark">@item.OrderDate.Value.ToString("dd MMM yyyy")</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">@item.OrderDate.Value.ToString("HH:mm") น.</div>
                                </td>
                                <td>
                                    <div class="fw-semibold">@item.Supplier?.Name</div>
                                    <div class="text-muted small">ID: @item.SupplierId</div>
                                </td>
                                <td class="text-end">
                                    <span class="amount-text">฿@item.TotalAmount.ToString("N2")</span>
                                </td>
                                <td class="text-center">
                                    @if (item.Status == "Pending")
                                    {
                                        <span class="status-badge bg-warning-subtle text-warning border border-warning border-opacity-25">
                                            <i class="bi bi-clock-history"></i> รอรับสินค้า
                                        </span>
                                    }
                                    else if (item.Status == "Received")
                                    {
                                        <span class="status-badge bg-success-subtle text-success border border-success border-opacity-25">
                                            <i class="bi bi-check-circle-fill"></i> รับสินค้าแล้ว
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <a href="@Url.Action("PODetails", "Manager", new { id = item.PoId })" 
                                       class="btn btn-primary btn-view-po shadow-sm">
                                        <i class="bi bi-eye-fill me-1"></i> รายละเอียด
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6">
                                <div class="empty-state">
                                    <i class="bi bi-inbox display-4 opacity-25"></i>
                                    <p class="mt-3 fs-5">ยังไม่มีประวัติการสั่งซื้อสินค้า</p>
                                    <a href="@Url.Action("CreatePO", "Manager")" class="btn btn-sm btn-outline-success">สร้างรายการแรก</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>