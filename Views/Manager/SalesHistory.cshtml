@model IEnumerable<FertilizerShop.Models.Order>
@{
    ViewData["Title"] = "ประวัติการขาย";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clock-history"></i> ประวัติการขายสินค้า</h2>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>เลขที่ใบเสร็จ</th>
                    <th>วันที่-เวลา</th>
                    <th>แคชเชียร์</th>
                    <th>วิธีชำระเงิน</th>
                    <th class="text-end">ยอดสุทธิ</th>
                    <th class="text-center">จัดการ</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.ReceiptNo</td>
                        <td>@item.OrderDate.Value.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <i class="bi bi-person-badge"></i>
                            @item.Cashier?.FirstName @item.Cashier?.LastName
                        </td>
                        <td>
                            <span class="badge rounded-pill bg-info text-dark">
                                @(item.PaymentMethod == "Cash" ? "เงินสด" : item.PaymentMethod == "Transfer" ? "เงินโอน" :
                      "บัตรเครดิต")
                            </span>
                        </td>
                        <td class="text-end fw-bold text-success">฿ @item.NetAmount.ToString("N2")</td>
                        <td class="text-center">
                            <a href="@Url.Action("OrderDetails", "Manager", new { id = item.OrderId })"
                                   class="btn btn-sm btn-primary">
                                <i class="bi bi-search"></i> ดูรายละเอียด
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>