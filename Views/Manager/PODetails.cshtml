@model FertilizerShop.Models.Purchaseorder
@{
    ViewData["Title"] = "รายละเอียดใบสั่งซื้อ PO-" + Model.PoId.ToString("D4");
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var details = ViewBag.PODetails as IEnumerable<FertilizerShop.Models.Purchaseorderdetail>;
}

<style>
    /* เน้นความคมชัดและพื้นที่ว่างแบบระบบบริหารจัดการองค์กร */
    .doc-container { background-color: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; }
    
    /* ส่วนหัวเอกสาร: เลขที่และสถานะ */
    .doc-top-bar { background-color: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 25px 30px; }
    
    /* แถบสถานะการดำเนินงาน (Timeline) */
    .status-flow { display: flex; align-items: center; gap: 10px; margin-top: 12px; }
    .flow-step { font-size: 0.75rem; font-weight: 700; padding: 5px 15px; border-radius: 6px; text-transform: uppercase; }
    .step-done { background-color: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
    .step-active { background-color: #fffbeb; color: #92400e; border: 1px solid #fef3c7; animation: pulse 2s infinite; }
    .step-todo { background-color: #f1f5f9; color: #94a3b8; border: 1px solid #e2e8f0; }

    /* ตารางข้อมูลพื้นฐาน (Info Grid) */
    .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 25px; padding: 30px; border-bottom: 1px solid #f1f5f9; }
    .info-item label { display: block; font-size: 0.75rem; font-weight: 700; color: #64748b; margin-bottom: 6px; }
    .info-item span { font-size: 1rem; font-weight: 600; color: #1e293b; }

    /* การตกแต่งตารางรายการสินค้า */
    .line-items-table thead th { background-color: #ffffff; color: #1e293b; border-bottom: 2px solid #1e293b; font-size: 0.85rem; padding: 15px; }
    .line-items-table tbody td { border-bottom: 1px solid #f1f5f9; padding: 15px; font-size: 0.95rem; }

    /* กล่องสรุปยอดเงิน */
    .summary-box { background-color: #f8fafc; border-radius: 12px; padding: 25px; min-width: 350px; border: 1px solid #e2e8f0; }
    .summary-row { display: flex; justify-content: space-between; margin-bottom: 10px; }
    .total-highlight { font-size: 1.6rem; color: #1d976c; font-weight: 800; border-top: 2px solid #e2e8f0; padding-top: 15px; margin-top: 15px; }

    @@keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.7; }
        100% { opacity: 1; }
    }

    /* ซ่อนส่วนที่ไม่จำเป็นเวลาพิมพ์ */
    @@media print {
        .btn, .sidebar, .top-navbar, .no-print { display: none !important; }
        .doc-container { border: none; box-shadow: none; }
        body { background: white; }
    }
</style>

<div class="mb-4 d-flex justify-content-between align-items-end no-print">
    <div>
        <h4 class="fw-bold mb-1 text-dark">หน้าจอตรวจสอบเอกสาร</h4>
        <p class="text-muted small mb-0">ระบบบริหารจัดการการจัดซื้อสินค้าเข้าคลัง (ชาติชายฟาร์ม)</p>
    </div>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-outline-dark btn-sm rounded-3 px-3">
            <i class="bi bi-printer me-1"></i> พิมพ์ใบสั่งซื้อ
        </button>
        <a href="@Url.Action("POHistory", "Manager")" class="btn btn-light btn-sm border rounded-3 px-3">
            <i class="bi bi-x-lg me-1"></i> ปิดหน้านี้
        </a>
    </div>
</div>

<div class="doc-container shadow-sm mb-5">
    <!-- ส่วนหัวเอกสาร: ประเภทและสถานะปัจจุบัน -->
    <div class="doc-top-bar d-flex justify-content-between align-items-start">
        <div>
            <h2 class="fw-bold mb-0" style="letter-spacing: 1px; color: #1e293b;">ใบสั่งซื้อสินค้า</h2>
            <div class="status-flow">
                <span class="flow-step step-done"><i class="bi bi-check2"></i> ออกเอกสารแล้ว</span>
                <i class="bi bi-chevron-right text-muted small"></i>
                @if (Model.Status == "Pending") {
                    <span class="flow-step step-active">อยู่ระหว่างรอรับสินค้า</span>
                    <i class="bi bi-chevron-right text-muted small"></i>
                    <span class="flow-step step-todo">เสร็จสมบูรณ์</span>
                } else {
                    <span class="flow-step step-done"><i class="bi bi-check2"></i> รับสินค้าเข้าคลังแล้ว</span>
                    <i class="bi bi-chevron-right text-muted small"></i>
                    <span class="flow-step step-done">รายการเสร็จสมบูรณ์</span>
                }
            </div>
        </div>
        <div class="text-end">
            <div class="h3 fw-bold mb-0 text-primary">#PO-@Model.PoId.ToString("D4")</div>
            <span class="text-muted small">รหัสอ้างอิงระบบ: <strong>SYS-REF-@Model.PoId</strong></span>
        </div>
    </div>

    <!-- รายละเอียดข้อมูลทั่วไปของใบสั่งซื้อ -->
    <div class="info-grid">
        <div class="info-item">
            <label>ชื่อผู้จัดจำหน่าย / แหล่งที่มา</label>
            <span>@Model.Supplier?.Name</span>
        </div>
        <div class="info-item">
            <label>วันที่สั่งซื้อสินค้า</label>
            <span>@Model.OrderDate.Value.ToString("dd MMMM yyyy")</span>
        </div>
        <div class="info-item">
            <label>เวลาที่บันทึกรายการ</label>
            <span>@Model.OrderDate.Value.ToString("HH:mm") น.</span>
        </div>
        <div class="info-item">
            <label>ผู้ออกเอกสาร</label>
            <span>ผู้จัดการระบบ (Admin)</span>
        </div>
    </div>

    <!-- ตารางแสดงรายการสินค้าที่สั่งซื้อ -->
    <div class="table-responsive">
        <table class="table mb-0 line-items-table">
            <thead>
                <tr>
                    <th width="60px" class="ps-4">ลำดับ</th>
                    <th>รายละเอียดสินค้า / รหัสสินค้า</th>
                    <th class="text-center">จำนวนที่สั่ง</th>
                    <th class="text-end">ต้นทุนต่อหน่วย</th>
                    <th class="text-end pe-4">ยอดรวม (บาท)</th>
                </tr>
            </thead>
            <tbody>
                @{ int i = 1; }
                @foreach (var d in details)
                {
                    <tr>
                        <td class="ps-4 text-muted">@(i++)</td>
                        <td>
                            <div class="fw-bold">@d.Product?.Name</div>
                            <div class="text-muted" style="font-size: 0.8rem;">รหัสสินค้า: @d.Product?.Sku</div>
                        </td>
                        <td class="text-center fw-bold text-dark">@d.Quantity.ToString("N0")</td>
                        <td class="text-end text-muted">@d.UnitCost.ToString("N2")</td>
                        <td class="text-end fw-bold">@d.SubTotal.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- ส่วนสรุปยอดเงินและการจัดการสต็อก -->
    <div class="p-4 d-flex flex-column flex-md-row justify-content-between align-items-start gap-5 border-top bg-white">
        <div class="flex-grow-1 no-print">
            @if (Model.Status == "Pending")
            {
                <div class="alert alert-info border-0 bg-light p-4 shadow-sm" style="border-radius: 12px; border-left: 5px solid #0dcaf0 !important;">
                    <h6 class="fw-bold mb-2 text-dark"><i class="bi bi-box-seam-fill me-2"></i> ขั้นตอนการตรวจรับสินค้า (Inbound)</h6>
                    <p class="small text-muted mb-3">กรุณาตรวจสอบสภาพสินค้าและจำนวนที่ได้รับจริงให้ตรงกับรายการสั่งซื้อ เมื่อตรวจสอบเรียบร้อยแล้ว กดยืนยันเพื่อนำสินค้าเข้าสู่คลังสินค้าของร้าน</p>
                    <form asp-action="MarkPOAsReceived" method="post">
                        <input type="hidden" name="id" value="@Model.PoId" />
                        <button type="submit" class="btn btn-dark fw-bold px-4 rounded-3 shadow-sm" 
                                onclick="return confirm('ยืนยันการรับสินค้าเข้าสต็อก? ระบบจะทำการเพิ่มจำนวนสินค้าโดยอัตโนมัติ');">
                            <i class="bi bi-check-lg me-1"></i> ยืนยันการรับสินค้าเข้าสต็อก
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="p-3 bg-success-subtle text-success rounded-3 border border-success border-opacity-10 d-inline-block">
                    <i class="bi bi-check-all me-1"></i> รายการจัดซื้อนี้ได้รับการตรวจสอบและบันทึกเข้าสต็อกเรียบร้อยแล้ว
                </div>
            }
        </div>
        
        <div class="summary-box shadow-sm">
            <div class="summary-row">
                <span class="text-muted">รวมเงินมูลค่าสินค้า</span>
                <span class="fw-bold text-dark">@Model.TotalAmount.ToString("N2")</span>
            </div>
            <div class="summary-row">
                <span class="text-muted">ภาษีมูลค่าเพิ่ม (0%)</span>
                <span class="text-muted">0.00</span>
            </div>
            <div class="summary-row total-highlight">
                <span>ยอดเงินสุทธิ</span>
                <span>฿ @Model.TotalAmount.ToString("N2")</span>
            </div>
        </div>
    </div>
</div>

<div class="text-center no-print pb-5">
    <p class="text-muted small"><i class="bi bi-shield-check me-1"></i> เอกสารอิเล็กทรอนิกส์ฉบับนี้ถูกสร้างขึ้นโดยระบบบริหารจัดการร้านชาติชายฟาร์ม</p>
</div>