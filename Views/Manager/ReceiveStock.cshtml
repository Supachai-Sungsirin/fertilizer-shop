@model FertilizerShop.ViewModels.ReceiveStockViewModel
@{
    ViewData["Title"] = "รับสินค้าเข้าสต็อก";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .receive-card {
        border-radius: 20px;
        border: none;
        background: #ffffff;
    }

    .form-label {
        font-size: 0.95rem;
        color: #475569;
        margin-bottom: 10px;
    }

    .form-control-lg, .form-select-lg {
        border-radius: 12px;
        border: 1px solid #cbd5e1;
        padding: 12px 20px;
        font-size: 1.1rem;
    }

    .form-control-lg:focus, .form-select-lg:focus {
        border-color: #1d976c;
        box-shadow: 0 0 0 4px rgba(29, 151, 108, 0.1);
    }

    .input-group-text {
        border-radius: 0 12px 12px 0 !important;
        background-color: #f8fafc;
        border: 1px solid #cbd5e1;
        border-left: none;
        color: #64748b;
        font-weight: 600;
    }

    .btn-receive {
        background: linear-gradient(45deg, #1d976c, #167a57);
        border: none;
        border-radius: 12px;
        padding: 15px;
        font-size: 1.2rem;
        transition: all 0.3s ease;
    }

    .btn-receive:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(29, 151, 108, 0.3);
        color: white;
    }

    .info-box {
        background-color: #f0fdf4;
        border-radius: 15px;
        padding: 20px;
        border-left: 5px solid #1d976c;
    }
</style>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-box-arrow-in-down text-success me-2"></i> รับสินค้าเข้าสต็อก</h2>
        <p class="text-muted small mb-0">บันทึกรายการสินค้าที่นำมาส่งเพื่อเพิ่มจำนวนในระบบ</p>
    </div>
    <a href="@Url.Action("Products", "Owner")" class="btn btn-outline-secondary px-4 shadow-sm" style="border-radius: 10px;">
        <i class="bi bi-box-seam me-1"></i> ตรวจสอบสต็อกทั้งหมด
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4 animate__animated animate__fadeIn" 
         style="border-radius: 15px; background-color: #dcfce7; color: #166534;">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-lg-6">
        <div class="card receive-card shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <form asp-action="ReceiveStock" method="post">
                    
                    <div class="mb-4">
                        <label asp-for="ProductId" class="form-label fw-bold d-flex align-items-center">
                            <i class="bi bi-search me-2 text-primary"></i> เลือกรายการสินค้า
                        </label>
                        <select asp-for="ProductId" asp-items="ViewBag.ProductList" class="form-select form-select-lg shadow-sm">
                            <option value="">-- ค้นหาชื่อสินค้า หรือ SKU --</option>
                        </select>
                        <span asp-validation-for="ProductId" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-5">
                        <label asp-for="QuantityAdded" class="form-label fw-bold d-flex align-items-center">
                            <i class="bi bi-plus-square-fill me-2 text-success"></i> จำนวนที่รับเข้า
                        </label>
                        <div class="input-group input-group-lg shadow-sm">
                            <input asp-for="QuantityAdded" class="form-control form-control-lg border-end-0" type="number" min="1" placeholder="เช่น 50" />
                            <span class="input-group-text">หน่วย / กระสอบ</span>
                        </div>
                        <span asp-validation-for="QuantityAdded" class="text-danger small mt-1 d-block"></span>
                        <div class="form-text mt-2 small text-muted">กรุณาตรวจสอบจำนวนสินค้าจริงหน้ากระสอบก่อนบันทึก</div>
                    </div>

                    <button type="submit" class="btn btn-success btn-receive w-100 fw-bold shadow">
                        <i class="bi bi-cloud-arrow-up-fill me-2"></i> บันทึกข้อมูลเข้าสต็อก
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5 offset-lg-1 d-none d-lg-block">
        <div class="info-box shadow-sm mb-4">
            <h5 class="fw-bold text-success mb-3"><i class="bi bi-lightbulb"></i> ข้อควรระวัง</h5>
            <ul class="text-muted small mb-0 lh-lg">
                <li>ตรวจสอบ <strong>SKU</strong> หรือชื่อสินค้าให้ตรงตามใบส่งของ</li>
                <li>เช็คสภาพสินค้าว่าไม่มีการแตกหักหรือเสียหาย</li>
                <li>หากเป็นสินค้าที่มีวันหมดอายุ กรุณาตรวจสอบก่อนจัดเก็บ</li>
                <li>จำนวนที่ระบุจะถูกนำไป <strong>บวกเพิ่ม</strong> จากจำนวนเดิมที่มีอยู่</li>
            </ul>
        </div>
        
        <div class="text-center p-4">
            <img src="https://cdn-icons-png.flaticon.com/512/3045/3045470.png" class="img-fluid opacity-25" style="max-width: 200px;" alt="Stock Icon">
        </div>
    </div>
</div>
