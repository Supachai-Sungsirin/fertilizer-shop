@model FertilizerShop.Models.Order
@{
    ViewData["Title"] = "รายละเอียดบิล";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var details = ViewBag.OrderDetails as IEnumerable<FertilizerShop.Models.Orderdetail>;
}

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="@Url.Action("SalesHistory", "Manager")">ประวัติการขาย</a></li>
    <li class="breadcrumb-item active">@Model.ReceiptNo</li>
  </ol>
</nav>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-success">รายละเอียดใบเสร็จ: @Model.ReceiptNo</h5>
        <a href="@Url.Action("Receipt", "Cashier", new { id = Model.OrderId })" target="_blank" class="btn btn-outline-dark btn-sm">
            <i class="bi bi-printer"></i> พิมพ์ใบเสร็จซ้ำ
        </a>
    </div>
    <div class="card-body">
        <div class="row mb-4">
            <div class="col-sm-6">
                <p class="text-muted mb-1">ข้อมูลทั่วไป</p>
                <h6 class="fw-bold">วันที่: @Model.OrderDate.Value.ToString("dd/MM/yyyy HH:mm")</h6>
                <h6>พนักงานขาย: @Model.Cashier?.FirstName @Model.Cashier?.LastName</h6>
            </div>
            <div class="col-sm-6 text-sm-end">
                <p class="text-muted mb-1">สถานะการชำระเงิน</p>
                <h6 class="fw-bold text-primary">วิธีชำระ: @Model.PaymentMethod</h6>
                <h6 class="text-danger">ส่วนลด: ฿ @Model.DiscountAmount?.ToString("N2")</h6>
            </div>
        </div>

        <table class="table table-bordered">
            <thead class="table-light">
                <tr>
                    <th>สินค้า</th>
                    <th class="text-center">ราคา/หน่วย</th>
                    <th class="text-center">จำนวน</th>
                    <th class="text-end">รวม</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in details)
                {
                    <tr>
                        <td>@d.Product?.Name</td>
                        <td class="text-center">@d.UnitPrice.ToString("N2")</td>
                        <td class="text-center">@d.Quantity</td>
                        <td class="text-end">@d.SubTotal.ToString("N2")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3" class="text-end">ยอดรวมทั้งสิ้น</th>
                    <th class="text-end fs-5 text-success">฿ @Model.NetAmount.ToString("N2")</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>