@model FertilizerShop.ViewModels.PromotionViewModel
@{
    ViewData["Title"] = "สร้างโปรโมชั่นใหม่";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .form-card {
        border-radius: 15px;
        background-color: #ffffff;
    }

    .section-box {
        border-radius: 12px;
        transition: all 0.3s ease;
        border: 1px solid #eef2f7;
    }

    .section-box:hover {
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .form-label {
        font-size: 0.9rem;
        color: #475569;
        margin-bottom: 8px;
    }

    .form-control, .form-select {
        border-radius: 10px;
        padding: 10px 15px;
        border: 1px solid #cbd5e1;
    }

    .form-control:focus, .form-select:focus {
        border-color: #1d976c;
        box-shadow: 0 0 0 3px rgba(29, 151, 108, 0.1);
    }

    .btn-save-promo {
        background: linear-gradient(45deg, #1d976c, #167a57);
        border: none;
        border-radius: 10px;
        padding: 12px 30px;
        font-weight: 600;
        transition: all 0.3s;
    }

    .btn-save-promo:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(29, 151, 108, 0.3);
    }

    .icon-step {
        width: 35px;
        height: 35px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        margin-right: 10px;
        font-weight: bold;
    }
</style>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-plus-circle-fill text-success me-2"></i> สร้างโปรโมชั่นใหม่</h2>
        <p class="text-muted small mb-0">กำหนดแคมเปญส่วนลดเพื่อดึงดูดลูกค้าและเพิ่มยอดขายของร้าน</p>
    </div>
    <a href="@Url.Action("Promotions", "Manager")" class="btn btn-outline-secondary px-4 shadow-sm" style="border-radius: 10px;">
        <i class="bi bi-arrow-left me-1"></i> กลับหน้าจัดการ
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card form-card shadow-sm border-0 mb-5">
            <div class="card-body p-4 p-md-5">
                <form asp-action="AddPromotion" method="post">
                    
                    <!-- ชื่อโปรโมชั่น -->
                    <div class="mb-5">
                        <label asp-for="Name" class="form-label fw-bold text-dark fs-6">ชื่อโปรโมชั่น / ชื่อแคมเปญ</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="border-radius: 10px 0 0 10px;">
                                <i class="bi bi- megaphone text-success"></i>
                            </span>
                            <input asp-for="Name" class="form-control form-control-lg border-start-0 ps-1" 
                                   placeholder="เช่น ซื้อครบ 1,000 ลด 100 บาท" style="border-radius: 0 10px 10px 0;" />
                        </div>
                        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="section-box bg-light p-4 h-100 border-top border-primary border-4">
                                <h5 class="text-primary mb-4 d-flex align-items-center fw-bold">
                                    <span class="icon-step bg-primary text-white">1</span> กำหนดเงื่อนไข
                                </h5>
                                <div class="mb-3">
                                    <label asp-for="ConditionType" class="form-label fw-bold">ประเภทเงื่อนไข</label>
                                    <select asp-for="ConditionType" class="form-select shadow-sm">
                                        <option value="">-- เลือกเงื่อนไข --</option>
                                        <option value="MinAmount">💰 ยอดซื้อขั้นต่ำ (บาท)</option>
                                        <option value="MinQuantity">📦 จำนวนชิ้นขั้นต่ำ (ชิ้น/กระสอบ)</option>
                                        <option value="MinWeight">⚖️ น้ำหนักรวมขั้นต่ำ (กก.)</option> 
                                    </select>
                                    <span asp-validation-for="ConditionType" class="text-danger small mt-1 d-block"></span>
                                </div>
                                <div class="mb-0">
                                    <label asp-for="ConditionValue" class="form-label fw-bold">มูลค่าเงื่อนไข</label>
                                    <input asp-for="ConditionValue" class="form-control shadow-sm" type="number" step="0.01" placeholder="เช่น 1000, 10, หรือ 20 (กก.)" />
                                    <span asp-validation-for="ConditionValue" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="section-box bg-light p-4 h-100 border-top border-success border-4">
                                <h5 class="text-success mb-4 d-flex align-items-center fw-bold">
                                    <span class="icon-step bg-success text-white">2</span> กำหนดรางวัล
                                </h5>
                                <div class="mb-3">
                                    <label asp-for="RewardType" class="form-label fw-bold">ประเภทยกเว้น/ส่วนลด</label>
                                    <select asp-for="RewardType" class="form-select shadow-sm">
                                        <option value="">-- เลือกประเภทรางวัล --</option>
                                        <option value="DiscountBaht">💵 ลดเป็นบาท (Baht)</option>
                                        <option value="DiscountPercent">📉 ลดเป็นเปอร์เซ็นต์ (%)</option>
                                        <option value="FreeShipping">🚚 จัดส่งฟรี</option>
                                        <option value="FreeItem">🎁 แถมสินค้าฟรี</option>
                                    </select>
                                    <span asp-validation-for="RewardType" class="text-danger small mt-1 d-block"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="RewardValue" class="form-label fw-bold">มูลค่าส่วนลด (ใส่ 0 ถ้าเป็นส่งฟรี/ของแถม)</label>
                                    <input asp-for="RewardValue" class="form-control shadow-sm" type="number" step="0.01" placeholder="เช่น 100 หรือ 0" />
                                    <span asp-validation-for="RewardValue" class="text-danger small mt-1 d-block"></span>
                                </div>
                                <div class="mb-0 border-top pt-3 mt-3 border-success border-opacity-25">
                                    <label asp-for="RewardItemName" class="form-label fw-bold text-success">ชื่อของแถม / ข้อความ (ถ้ามี)</label>
                                    <input asp-for="RewardItemName" class="form-control shadow-sm border-success border-opacity-50" placeholder="เช่น จัดส่งฟรี, น้ำยาฆ่าแมลง 1 ขวด" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 text-center">
                        <hr class="mb-5 opacity-25">
                        <button type="submit" class="btn btn-success btn-save-promo btn-lg px-5 shadow">
                            <i class="bi bi-save-fill me-2"></i> บันทึกและเปิดใช้งานโปรโมชั่น
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>