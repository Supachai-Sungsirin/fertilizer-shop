@model FertilizerShop.ViewModels.PromotionViewModel
@{
    ViewData["Title"] = "สร้างโปรโมชั่นใหม่";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-plus-circle"></i> สร้างโปรโมชั่นใหม่</h2>
    <a href="@Url.Action("Promotions", "Manager")" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> กลับ</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="AddPromotion" method="post">
            
            <div class="mb-4">
                <label asp-for="Name" class="form-label fw-bold"></label>
                <input asp-for="Name" class="form-control form-control-lg" placeholder="เช่น ซื้อครบ 1,000 ลด 100 บาท" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="row mb-4 bg-light p-3 rounded">
                <h5 class="text-primary mb-3"><i class="bi bi-1-circle"></i> กำหนดเงื่อนไข (Condition)</h5>
                <div class="col-md-6">
                    <label asp-for="ConditionType" class="form-label fw-bold"></label>
                    <select asp-for="ConditionType" class="form-select">
                        <option value="">-- เลือกเงื่อนไข --</option>
                        <option value="MinAmount">ยอดซื้อขั้นต่ำ (บาท)</option>
                        <option value="MinQuantity">จำนวนชิ้นขั้นต่ำ (ชิ้น/กระสอบ)</option>
                    </select>
                    <span asp-validation-for="ConditionType" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ConditionValue" class="form-label fw-bold"></label>
                    <input asp-for="ConditionValue" class="form-control" type="number" step="0.01" placeholder="เช่น 1000" />
                    <span asp-validation-for="ConditionValue" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-4 bg-light p-3 rounded">
                <h5 class="text-success mb-3"><i class="bi bi-2-circle"></i> กำหนดส่วนลด (Reward)</h5>
                <div class="col-md-6">
                    <label asp-for="RewardType" class="form-label fw-bold"></label>
                    <select asp-for="RewardType" class="form-select">
                        <option value="">-- เลือกประเภทส่วนลด --</option>
                        <option value="DiscountBaht">ลดราคาเป็นบาท (Baht)</option>
                        <option value="DiscountPercent">ลดราคาเป็นเปอร์เซ็นต์ (%)</option>
                    </select>
                    <span asp-validation-for="RewardType" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="RewardValue" class="form-label fw-bold"></label>
                    <input asp-for="RewardValue" class="form-control" type="number" step="0.01" placeholder="เช่น 100 หรือ 10" />
                    <span asp-validation-for="RewardValue" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-success px-4"><i class="bi bi-save"></i> บันทึกข้อมูล</button>
        </form>
    </div>
</div>