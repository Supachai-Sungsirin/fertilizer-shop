@model IEnumerable<FertilizerShop.Models.Product>
@{
    ViewData["Title"] = "จัดการข้อมูลสินค้า";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam"></i> รายการสินค้าทั้งหมด</h2>
    <a href="@Url.Action("AddProduct", "Owner")" class="btn btn-success"><i class="bi bi-plus-circle"></i> เพิ่มสินค้าใหม่</a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>รหัส</th>
                    <th>ชื่อสินค้า</th>
                    <th>หมวดหมู่</th>
                    <th class="text-end">ราคาขาย</th>
                    <th class="text-end">คงเหลือ (ชิ้น/กระสอบ)</th>
                    <th class="text-center">จัดการ</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td class="text-muted">P-@p.ProductId.ToString("D3")</td>
                        <td class="fw-bold text-success">@p.Name</td>
                        <td><span class="badge bg-secondary">@p.Category.CategoryName</span></td>
                        <td class="text-end">฿ @p.Price.ToString("N2")</td>
                        <td class="text-end">
                            @if(p.StockQuantity <= 5) {
                                <span class="text-danger fw-bold"><i class="bi bi-exclamation-circle"></i> @p.StockQuantity</span>
                            } else {
                                <span>@p.StockQuantity</span>
                            }
                        </td>
                        <td class="text-center">
                            <a href="@Url.Action("EditProduct", "Owner", new { id = p.ProductId })" class="btn btn-sm btn-outline-warning" title="แก้ไข">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <a href="@Url.Action("DeleteProduct", "Owner", new { id = p.ProductId })" 
                               class="btn btn-sm btn-outline-danger" 
                               onclick="return confirm('ลบสินค้า @p.Name ใช่หรือไม่?');" title="ลบ">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>