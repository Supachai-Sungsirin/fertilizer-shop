@model IEnumerable<FertilizerShop.Models.User>
@using System.Security.Claims

@{
    ViewData["Title"] = "จัดการพนักงาน";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var currentUserId = int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier));
}

<style>
    .employee-table thead th {
        background-color: #f8fafc;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        font-weight: 700;
        color: #64748b;
        padding: 15px;
        border-top: none;
    }

    .employee-table tbody td {
        padding: 15px;
        vertical-align: middle;
    }

    .avatar-circle {
        width: 40px;
        height: 40px;
        background-color: #e2e8f0;
        color: #475569;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-weight: bold;
    }

    .role-badge {
        font-size: 0.75rem;
        padding: 5px 12px;
        border-radius: 50px;
        font-weight: 600;
    }

    .status-indicator {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 5px;
    }

    .btn-action {
        width: 34px;
        height: 34px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s;
    }

    .btn-action:hover {
        transform: translateY(-2px);
    }

    .card-custom {
        border-radius: 15px;
        overflow: hidden;
    }
</style>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-people-fill text-success me-2"></i> จัดการพนักงาน</h2>
        <p class="text-muted small mb-0">ตรวจสอบและตั้งค่าสิทธิ์การเข้าใช้งานของทีมงานในร้าน</p>
    </div>
    <a href="@Url.Action("AddEmployee", "Owner")" class="btn btn-success shadow-sm px-4 py-2" style="border-radius: 10px;">
        <i class="bi bi-person-plus-fill me-2"></i> เพิ่มพนักงานใหม่
    </a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px;">
        <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card card-custom border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 employee-table">
                <thead>
                    <tr>
                        <th class="ps-4">รหัส / พนักงาน</th>
                        <th>ตำแหน่ง</th>
                        <th>สถานะ</th>
                        <th class="text-center pe-4">การจัดการ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle me-3 shadow-sm bg-success-subtle text-success">
                                        @user.FirstName.Substring(0, 1)
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@user.FirstName @user.LastName</div>
                                        <small class="text-muted">ID: <span class="text-success fw-bold">@user.EmployeeId</span></small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (user.Role.RoleName == "Owner")
                                {
                                    <span class="badge bg-danger-subtle text-danger role-badge">เจ้าของร้าน</span>
                                }
                                else if (user.Role.RoleName == "Manager")
                                {
                                    <span class="badge bg-primary-subtle text-primary role-badge">ผู้จัดการ</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary role-badge">แคชเชียร์</span>
                                }
                            </td>
                            <td>
                                @if (user.IsActive == true)
                                {
                                    <span class="text-success small fw-bold">
                                        <span class="status-indicator bg-success"></span> เปิดใช้งาน
                                    </span>
                                }
                                else
                                {
                                    <span class="text-danger small fw-bold">
                                        <span class="status-indicator bg-danger"></span> ระงับการใช้งาน
                                    </span>
                                }
                            </td>
                            <td class="text-center pe-4">
                                <div class="d-flex justify-content-center gap-2">
                                    <a href="@Url.Action("EditEmployee", "Owner", new { id = user.UserId })"
                                       class="btn btn-action btn-outline-warning" title="แก้ไขข้อมูล">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>

                                    @if (user.UserId == currentUserId)
                                    {
                                        <button class="btn btn-action btn-light" disabled title="บัญชีของคุณ">
                                            <i class="bi bi-person-check-fill text-muted"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <a href="@Url.Action("ToggleStatus", "Owner", new { id = user.UserId })"
                                           class="btn btn-action @(user.IsActive == true ? "btn-outline-danger" : "btn-outline-success")"
                                           onclick="return confirm('ยืนยันการเปลี่ยนสถานะการใช้งานของพนักงานท่านนี้?');"
                                           title="@(user.IsActive == true ? "ระงับการใช้งาน" : "เปิดใช้งาน")">
                                            <i class="bi @(user.IsActive == true ? "bi-person-x-fill" : "bi-person-check-fill")"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>