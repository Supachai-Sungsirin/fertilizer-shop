@model FertilizerShop.ViewModels.ProductViewModel
@{
    ViewData["Title"] = "เพิ่มสินค้าใหม่";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .form-card {
        border-radius: 20px;
        background-color: #ffffff;
    }

    .section-label {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #1d976c;
        font-weight: 700;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
    }

    .section-label::after {
        content: "";
        flex: 1;
        height: 1px;
        background: #f1f5f9;
        margin-left: 15px;
    }

    .form-label {
        font-size: 0.9rem;
        color: #475569;
        margin-bottom: 8px;
    }

    .form-control, .form-select {
        border-radius: 12px;
        padding: 10px 15px;
        border: 1px solid #cbd5e1;
        transition: all 0.2s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: #1d976c;
        box-shadow: 0 0 0 4px rgba(29, 151, 108, 0.1);
    }

    .input-group-text {
        background-color: #f8fafc;
        border: 1px solid #cbd5e1;
        color: #64748b;
        border-radius: 12px;
    }

    /* ปรับแต่ง input group ให้โค้งมนสวยงาม */
    .input-group > .form-control:first-child, 
    .input-group > .input-group-text:first-child {
        border-top-left-radius: 12px;
        border-bottom-left-radius: 12px;
    }

    .input-group > .form-control:last-child, 
    .input-group > .input-group-text:last-child {
        border-top-right-radius: 12px;
        border-bottom-right-radius: 12px;
    }

    .btn-save-product {
        background: linear-gradient(45deg, #1d976c, #167a57);
        border: none;
        border-radius: 12px;
        padding: 12px 30px;
        font-weight: 600;
        transition: all 0.3s;
    }

    .btn-save-product:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 15px rgba(29, 151, 108, 0.3);
        color: white;
    }
</style>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-plus-circle-fill text-success me-2"></i> เพิ่มสินค้าใหม่</h2>
        <p class="text-muted small mb-0">บันทึกข้อมูลสินค้าปุ๋ยและวัสดุทางการเกษตรเข้าสู่ระบบคลังสินค้า</p>
    </div>
    <a href="@Url.Action("Products", "Owner")" class="btn btn-outline-secondary px-4 shadow-sm" style="border-radius: 10px;">
        <i class="bi bi-arrow-left me-1"></i> กลับหน้ารายการ
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card form-card shadow-sm border-0 mb-5">
            <div class="card-body p-4 p-md-5">
                <form asp-action="AddProduct" method="post" enctype="multipart/form-data">
                    
                    <div class="section-label">
                        <i class="bi bi-info-square-fill me-2"></i> ข้อมูลพื้นฐานสินค้า
                    </div>

                    <div class="row g-4 mb-5">
                        <div class="mb-3">
                            <label asp-for="ImageUpload" class="form-label">รูปภาพสินค้า</label>
                            <input asp-for="ImageUpload" type="file" class="form-control" accept="image/*" />
                            <span asp-validation-for="ImageUpload" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Sku" class="form-label fw-bold"></label>
                            <input asp-for="Sku" class="form-control" placeholder="เช่น P-001" />
                            <span asp-validation-for="Sku" class="text-danger small"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label fw-bold"></label>
                            <input asp-for="Name" class="form-control" placeholder="ชื่อสินค้าปุ๋ย/เคมีเกษตร" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label fw-bold"></label>
                            <select asp-for="CategoryId" asp-items="ViewBag.CategoryList" class="form-select">
                                <option value="">-- เลือกหมวดหมู่สินค้า --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="WeightPerUnit" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <input asp-for="WeightPerUnit" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                <span class="input-group-text">กิโลกรัม (kg)</span>
                            </div>
                            <span asp-validation-for="WeightPerUnit" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="section-label">
                        <i class="bi bi-tags-fill me-2"></i> ราคาและคลังสินค้า
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label asp-for="Price" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text">฿</span>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StockQuantity" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <input asp-for="StockQuantity" class="form-control" type="number" placeholder="0" />
                                <span class="input-group-text">หน่วย</span>
                            </div>
                            <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ExpiryDate" class="form-label fw-bold"></label>
                            <input asp-for="ExpiryDate" class="form-control" type="date" />
                            <div class="form-text small">ระบุหากสินค้ามีวันหมดอายุ</div>
                        </div>
                    </div>

                    <div class="mt-5 pt-4 border-top">
                        <div class="d-flex justify-content-end gap-2">
                            <button type="reset" class="btn btn-light btn-sm px-3 text-secondary">
                                <i class="bi bi-arrow-counterclockwise"></i> ล้างค่า
                            </button>
                            <button type="submit" class="btn btn-success btn-save-product px-5 shadow-sm">
                                <i class="bi bi-check-circle-fill me-2"></i> บันทึกรายการสินค้า
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>