@model FertilizerShop.ViewModels.ProductViewModel
@{
    ViewData["Title"] = "เพิ่มสินค้าใหม่";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-plus-circle"></i> เพิ่มสินค้าใหม่</h2>
    <a href="@Url.Action("Products", "Owner")" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> กลับ</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="AddProduct" method="post">
            <div class="row mb-3">
                <div class="col-md-4">
                    <label asp-for="Sku" class="form-label fw-bold"></label>
                    <input asp-for="Sku" class="form-control" placeholder="เช่น P001" />
                    <span asp-validation-for="Sku" class="text-danger"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label fw-bold"></label>
                    <input asp-for="Name" class="form-control" placeholder="เช่น ปุ๋ยตรากระต่าย สูตร 15-15-15" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label fw-bold"></label>
                    <select asp-for="CategoryId" asp-items="ViewBag.CategoryList" class="form-select">
                        <option value="">-- เลือกหมวดหมู่ --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="WeightPerUnit" class="form-label fw-bold"></label>
                    <div class="input-group">
                        <input asp-for="WeightPerUnit" class="form-control" type="number" step="0.01" />
                        <span class="input-group-text">กิโลกรัม</span>
                    </div>
                    <span asp-validation-for="WeightPerUnit" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-4">
                    <label asp-for="Price" class="form-label fw-bold"></label>
                    <div class="input-group">
                        <span class="input-group-text">฿</span>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    </div>
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="StockQuantity" class="form-label fw-bold"></label>
                    <input asp-for="StockQuantity" class="form-control" type="number" />
                    <span asp-validation-for="StockQuantity" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ExpiryDate" class="form-label fw-bold"></label>
                    <input asp-for="ExpiryDate" class="form-control" type="date" />
                </div>
            </div>

            <button type="submit" class="btn btn-success px-4"><i class="bi bi-save"></i> บันทึกข้อมูล</button>
        </form>
    </div>
</div>
