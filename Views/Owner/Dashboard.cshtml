@{
    ViewData["Title"] = "แดชบอร์ด - ร้านปุ๋ย";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Bootstrap Icons CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<style>
    :root {
        --primary: #2d7a3a;
        --primary-light: #f0faf2;
        --success: #10b981;
        --success-light: #ecfdf5;
        --warning: #f59e0b;
        --warning-light: #fffbeb;
        --danger: #ef4444;
        --danger-light: #fef2f2;
        --info: #3b82f6;
        --info-light: #eff6ff;
        --text-dark: #1e293b;
        --text-muted: #64748b;
        --border: #e2e8f0;
        --bg-light: #f8fafc;
        --card-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.04);
        --card-shadow-hover: 0 4px 12px rgba(0,0,0,.10), 0 8px 24px rgba(0,0,0,.06);
    }

    body {
        background-color: var(--bg-light);
        color: var(--text-dark);
        font-family: 'Sarabun', 'Segoe UI', sans-serif;
    }

    /* ── Page header ── */
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: .75rem;
        margin-bottom: 1.75rem;
    }
    .page-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0;
    }
    .page-header .badge-live {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        font-size: .75rem;
        font-weight: 600;
        color: var(--success);
        background: var(--success-light);
        border: 1px solid #a7f3d0;
        border-radius: 999px;
        padding: .25rem .75rem;
    }
    .badge-live .dot {
        width: 7px; height: 7px;
        background: var(--success);
        border-radius: 50%;
        animation: pulse 1.8s ease-in-out infinite;
    }

    /* ── KPI cards ── */
    .kpi-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.4rem 1.5rem;
        box-shadow: var(--card-shadow);
        transition: box-shadow .2s, transform .2s;
        height: 100%;
        position: relative;
        overflow: hidden;
    }
    .kpi-card:hover {
        box-shadow: var(--card-shadow-hover);
        transform: translateY(-2px);
    }
    .kpi-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        border-radius: 14px 14px 0 0;
    }
    .kpi-card.c-success::before { background: var(--success); }
    .kpi-card.c-info::before    { background: var(--info); }
    .kpi-card.c-warning::before { background: var(--warning); }
    .kpi-card.c-danger::before  { background: var(--danger); }
    .kpi-card.c-primary::before { background: var(--primary); }

    .kpi-icon {
        width: 46px; height: 46px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }
    .kpi-icon.bg-success-soft { background: var(--success-light); color: var(--success); }
    .kpi-icon.bg-info-soft    { background: var(--info-light);    color: var(--info); }
    .kpi-icon.bg-warning-soft { background: var(--warning-light); color: var(--warning); }
    .kpi-icon.bg-danger-soft  { background: var(--danger-light);  color: var(--danger); }
    .kpi-icon.bg-primary-soft { background: var(--primary-light); color: var(--primary); }

    .kpi-label {
        font-size: .78rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: .05em;
        margin-bottom: .3rem;
    }
    .kpi-value {
        font-size: 1.7rem;
        font-weight: 800;
        color: var(--text-dark);
        line-height: 1.15;
        margin-bottom: .3rem;
    }
    .kpi-change {
        font-size: .78rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: .2rem;
    }
    .kpi-change.up   { color: var(--success); }
    .kpi-change.down { color: var(--danger); }

</style>

<div class="page-header">
    <div>
        <h2><i class="bi bi-flower1 me-2" style="color:var(--primary)"></i>แดชบอร์ดภาพรวม</h2>
    </div>
    <div class="d-flex align-items-center gap-2 flex-wrap">
        @* <span class="badge-live"><span class="dot"></span>Live Data</span> *@
        <select class="form-select form-select-sm" style="width:auto;font-size:.8rem;" id="dateRange">
            <option>วันนี้</option>
            <option>7 วันที่ผ่านมา</option>
            <option>30 วันที่ผ่านมา</option>
            <option>เดือนนี้</option>
        </select>
    </div>
</div>

<div class="row g-3 mb-4">

    <!-- ยอดขาย -->
    <div class="col-6 col-lg-3">
        <div class="kpi-card c-success">
            <div class="d-flex align-items-start justify-content-between">
                <div>
                    <p class="kpi-label">ยอดขายวันนี้</p>
                    <div class="kpi-value">฿38,500</div>
                </div>
                <div class="kpi-icon bg-success-soft"><i class="bi bi-currency-dollar"></i></div>
            </div>
        </div>
    </div>

    <!-- คำสั่งซื้อ -->
    <div class="col-6 col-lg-3">
        <div class="kpi-card c-info">
            <div class="d-flex align-items-start justify-content-between">
                <div>
                    <p class="kpi-label">บิลขายวันนี้</p>
                    <div class="kpi-value">17 บิล</div>
                </div>
                <div class="kpi-icon bg-info-soft"><i class="bi bi-receipt-cutoff"></i></div>
            </div>
        </div>
    </div>

    <!-- ปุ๋ยใกล้หมดสต็อก -->
    <div class="col-6 col-lg-3">
        <div class="kpi-card c-warning">
            <div class="d-flex align-items-start justify-content-between">
                <div>
                    <p class="kpi-label">สินค้าใกล้หมดสต็อก</p>
                    <div class="kpi-value">6 รายการ</div>
                </div>
                <div class="kpi-icon bg-warning-soft"><i class="bi bi-exclamation-triangle-fill"></i></div>
            </div>
        </div>
    </div>

    <!-- น้ำหนักปุ๋ยที่ขาย -->
    <div class="col-6 col-lg-3">
        <div class="kpi-card c-primary">
            <div class="d-flex align-items-start justify-content-between">
                <div>
                    <p class="kpi-label">ปุ๋ยที่ขายได้ (กก.)</p>
                    <div class="kpi-value">2,840 กก.</div>
                </div>
                <div class="kpi-icon bg-primary-soft"><i class="bi bi-bag-fill"></i></div>
            </div>
        </div>
    </div>

</div>

</div>

