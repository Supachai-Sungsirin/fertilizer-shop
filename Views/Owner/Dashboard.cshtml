@model FertilizerShop.ViewModels.OwnerDashboardViewModel
@{
    ViewData["Title"] = "แดชบอร์ดเจ้าของร้าน";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    /* Gradient Cards */
    .card-stat { border: none; border-radius: 20px; transition: all 0.3s ease; overflow: hidden; position: relative; }
    .card-stat:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
    
    .bg-grad-green { background: linear-gradient(135deg, #1d976c 0%, #116649 100%); }
    .bg-grad-blue { background: linear-gradient(135deg, #2193b0 0%, #1d6a80 100%); }
    .bg-grad-purple { background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%); }
    .bg-grad-red { background: linear-gradient(135deg, #ee0979 0%, #ff6a00 100%); }

    .stat-icon { position: absolute; right: -10px; bottom: -10px; font-size: 5rem; opacity: 0.15; transform: rotate(-15deg); }
    
    .table-custom thead th { 
        background-color: #f8fafc; 
        text-transform: uppercase; 
        font-size: 0.75rem; 
        letter-spacing: 1px; 
        border: none; 
    }
    
    .chart-container { position: relative; height: 300px; width: 100%; }

    .rank-badge {
        width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; font-weight: bold;
    }
</style>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-2">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-pie-chart-fill text-success me-2"></i> สรุปผลประกอบการ</h2>
        <p class="text-muted small mb-0">วิเคราะห์ยอดขายและประสิทธิภาพของร้าน "ชาติชายฟาร์ม"</p>
    </div>
    <div class="badge bg-white text-dark border p-2 shadow-sm rounded-pill">
        <i class="bi bi-clock-history me-1 text-success"></i> ข้อมูล ณ วันที่ @DateTime.Now.ToString("dd MMM yyyy HH:mm")
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card card-stat shadow-sm bg-grad-green text-white h-100">
            <div class="card-body p-4">
                <h6 class="opacity-75 fw-bold text-uppercase small">ยอดขายวันนี้</h6>
                <h2 class="mb-0 fw-bold">฿ @Model.TodaySales.ToString("N0")</h2>
                <div class="mt-2 small"><i class="bi bi-arrow-up-short"></i> อัปเดตล่าสุด</div>
                <i class="bi bi-currency-dollar stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card card-stat shadow-sm bg-grad-blue text-white h-100">
            <div class="card-body p-4">
                <h6 class="opacity-75 fw-bold text-uppercase small">รายได้เดือนนี้</h6>
                <h2 class="mb-0 fw-bold">฿ @Model.MonthSales.ToString("N0")</h2>
                <div class="mt-2 small"><i class="bi bi-calendar-check"></i> ประจำเดือนปัจจุบัน</div>
                <i class="bi bi-graph-up stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card card-stat shadow-sm bg-grad-purple text-white h-100">
            <div class="card-body p-4">
                <h6 class="opacity-75 fw-bold text-uppercase small">บิลทั้งหมด (เดือนนี้)</h6>
                <h2 class="mb-0 fw-bold">@Model.TotalOrdersMonth <span class="fs-4 fw-normal">บิล</span></h2>
                <div class="mt-2 small"><i class="bi bi-receipt"></i> ปริมาณการซื้อขาย</div>
                <i class="bi bi-cart4 stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card card-stat shadow-sm bg-grad-red text-white h-100">
            <div class="card-body p-4">
                <h6 class="opacity-75 fw-bold text-uppercase small">สินค้าที่ต้องสั่งเพิ่ม</h6>
                <h2 class="mb-0 fw-bold">@Model.LowStockCount <span class="fs-4 fw-normal">รายการ</span></h2>
                <div class="mt-2 small"><i class="bi bi-exclamation-circle"></i> ตรวจสอบคลังสินค้า</div>
                <i class="bi bi-box-seam stat-icon"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 h-100" style="border-radius: 20px;">
            <div class="card-header bg-white py-4 border-0">
                <h6 class="mb-0 fw-bold text-dark"><i class="bi bi-activity text-success me-2"></i> สถิติจำนวนเงินหมุนเวียน (7 วันล่าสุด)</h6>
            </div>
            <div class="card-body">
                <div class="chart-container">
                    <canvas id="salesChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm border-0 h-100" style="border-radius: 20px;">
            <div class="card-header bg-white py-4 border-0">
                <h6 class="mb-0 fw-bold text-dark"><i class="bi bi-fire text-orange me-2"></i> สินค้าขายดี (Top 5)</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle table-custom">
                        <thead>
                            <tr>
                                <th class="ps-4">สินค้า</th>
                                <th class="text-center">ยอดขาย</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TopProducts.Any()) {
                                int rank = 1;
                                foreach (var item in Model.TopProducts) {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="rank-badge rounded-circle me-3 @(rank == 1 ? "bg-warning text-dark" : "bg-light text-muted border")">@rank</div>
                                                <span class="fw-bold text-dark text-truncate" style="max-width: 140px;">@item.ProductName</span>
                                            </div>
                                        </td>
                                        <td class="text-center fw-bold text-success">@item.TotalQty <small class="text-muted fw-normal">ชิ้น</small></td>
                                    </tr>
                                    rank++;
                                }
                            } else {
                                <tr><td colspan="2" class="text-center py-5 text-muted small">ไม่มีข้อมูลการขาย</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-2 mb-5">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 border-top border-danger border-4 h-100" style="border-radius: 0 0 20px 20px;">
            <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold text-danger"><i class="bi bi-shield-fill-exclamation me-1"></i> สินค้าที่สต็อกใกล้หมด</h6>
                <a href="@Url.Action("Products", "Owner")" class="btn btn-sm btn-light rounded-pill px-3">ดูคลังสินค้า</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle table-custom">
                    <tbody>
                        @if (Model.LowStockProductsList.Any()) {
                            foreach (var item in Model.LowStockProductsList) {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold">@item.Name</div>
                                        <code class="small text-muted">@item.Sku</code>
                                    </td>
                                    <td class="text-end pe-4">
                                        <span class="badge @(item.StockQuantity == 0 ? "bg-dark" : "bg-danger") px-3 rounded-pill shadow-sm">
                                            @item.StockQuantity
                                        </span>
                                    </td>
                                </tr>
                            }
                        } else {
                            <tr><td colspan="2" class="text-center py-4 text-success"><i class="bi bi-check-circle"></i> สินค้าทุกรายการมีพอเพียง</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm border-0 border-top border-success border-4 h-100" style="border-radius: 0 0 20px 20px;">
            <div class="card-header bg-white py-3 border-0">
                <h6 class="mb-0 fw-bold text-success"><i class="bi bi-people-fill me-1"></i> พนักงานดีเด่น (Performance)</h6>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle table-custom">
                    <thead class="table-light">
                        <tr class="small">
                            <th class="ps-4">พนักงาน</th>
                            <th class="text-center">บิล</th>
                            <th class="text-end pe-4">ยอดรวม</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.TopEmployees.Any()) {
                            int empRank = 1;
                            foreach (var emp in Model.TopEmployees) {
                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold text-dark">@emp.EmployeeName</span>
                                    </td>
                                    <td class="text-center fw-bold">@emp.TotalBills</td>
                                    <td class="text-end pe-4 text-success fw-bold">฿@emp.TotalSales.ToString("N0")</td>
                                </tr>
                                empRank++;
                            }
                        } else {
                            <tr><td colspan="3" class="text-center py-4 text-muted">ไม่มีข้อมูล</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const labels = @Html.Raw(ViewBag.ChartLabels);
    const dataValues = @Html.Raw(ViewBag.ChartValues);

    const ctx = document.getElementById('salesChart').getContext('2d');
    
    // สร้าง Gradient สำหรับเส้นกราฟ
    const gradient = ctx.createLinearGradient(0, 0, 0, 400);
    gradient.addColorStop(0, 'rgba(29, 151, 108, 0.4)');
    gradient.addColorStop(1, 'rgba(29, 151, 108, 0.0)');

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                data: dataValues,
                borderColor: '#1d976c',
                backgroundColor: gradient,
                borderWidth: 4,
                pointBackgroundColor: '#ffffff',
                pointBorderColor: '#1d976c',
                pointBorderWidth: 2,
                pointRadius: 6,
                pointHoverRadius: 8,
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: '#1e293b',
                    titleFont: { family: 'Sarabun' },
                    bodyFont: { family: 'Sarabun' },
                    padding: 12,
                    displayColors: false,
                    callbacks: {
                        label: function(context) {
                            return 'ยอดขาย: ฿' + context.raw.toLocaleString();
                        }
                    }
                }
            },
            scales: {
                y: { 
                    beginAtZero: true, 
                    grid: { color: '#f1f5f9' },
                    ticks: { font: { family: 'Sarabun' } }
                },
                x: { 
                    grid: { display: false },
                    ticks: { font: { family: 'Sarabun' } }
                }
            }
        }
    });
</script>