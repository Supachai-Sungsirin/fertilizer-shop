@model FertilizerShop.ViewModels.CategoryViewModel
@{
    ViewData["Title"] = "แก้ไขหมวดหมู่สินค้า";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .form-card {
        border-radius: 20px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05) !important;
    }

    .form-header {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        padding: 25px;
        color: white;
    }

    .form-label {
        font-size: 0.9rem;
        color: #475569;
        margin-bottom: 8px;
    }

    .form-control-lg {
        border-radius: 12px;
        border: 1px solid #cbd5e1;
        padding: 12px 15px;
        font-size: 1rem;
        transition: all 0.2s ease;
    }

    .form-control-lg:focus {
        border-color: #f59e0b;
        box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.1);
    }

    .btn-action {
        border-radius: 12px;
        padding: 10px 24px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-update {
        background: linear-gradient(45deg, #f59e0b, #d97706);
        border: none;
        color: white;
    }

    .btn-update:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(217, 119, 6, 0.3);
        color: white;
    }

    .cat-id-info {
        background-color: #fffbeb;
        border-radius: 12px;
        padding: 12px;
        border: 1px solid #fef3c7;
        color: #92400e;
        font-size: 0.85rem;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            
            <div class="mb-4">
                <h2 class="fw-bold mb-1 text-dark">จัดการหมวดหมู่</h2>
                <p class="text-muted small">แก้ไขชื่อประเภทสินค้าเพื่อให้ตรงกับความต้องการปัจจุบัน</p>
            </div>

            <div class="card form-card border-0">
                <div class="form-header">
                    <h5 class="mb-0 fw-bold d-flex align-items-center">
                        <i class="bi bi-pencil-square me-2 fs-4"></i> แก้ไขข้อมูลหมวดหมู่
                    </h5>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="EditCategory" method="post">
                        <input type="hidden" asp-for="CategoryId" />

                        <div class="cat-id-info mb-4 d-flex align-items-center">
                            <i class="bi bi-info-circle-fill me-2 fs-5"></i>
                            <span>กำลังแก้ไขหมวดหมู่รหัส: <strong>CAT-@Model.CategoryId.ToString("D3")</strong></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CategoryName" class="form-label fw-bold">ชื่อหมวดหมู่สินค้า</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0" style="border-radius: 12px 0 0 12px;">
                                    <i class="bi bi-tag text-warning"></i>
                                </span>
                                <input asp-for="CategoryName" class="form-control form-control-lg border-start-0"
                                       placeholder="ระบุชื่อหมวดหมู่ใหม่" style="border-radius: 0 12px 12px 0;" />
                            </div>
                            <span asp-validation-for="CategoryName" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top">
                            <a href="@Url.Action("Categories", "Owner")" class="btn btn-outline-secondary btn-action">
                                <i class="bi bi-arrow-left me-1"></i> ยกเลิก
                            </a>

                            <button type="submit" class="btn btn-update btn-action shadow-sm">
                                <i class="bi bi-cloud-arrow-up-fill me-1"></i> อัปเดตข้อมูล
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
