@model FertilizerShop.Models.Product
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body { background-color: #f8fafc; }
    
    .breadcrumb-item + .breadcrumb-item::before { content: ">"; color: #94a3b8; }
    
    .product-detail-card {
        border-radius: 24px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05) !important;
    }

    .image-section {
        background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 450px;
        position: relative;
    }

    .price-display {
        font-size: 3rem;
        font-weight: 800;
        color: #dc3545;
        letter-spacing: -1px;
    }

    .info-box {
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 20px;
        background-color: #ffffff;
    }

    .btn-action {
        border-radius: 14px;
        padding: 16px 24px;
        font-size: 1.1rem;
        transition: all 0.3s ease;
    }

    .btn-action:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(25, 135, 84, 0.2);
    }

    .stock-status {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .feature-list {
        list-style: none;
        padding-left: 0;
    }

    .feature-list li {
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
        color: #475569;
    }
</style>

<div class="container mt-5 mb-5 animate__animated animate__fadeIn">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" class="text-success text-decoration-none fw-semibold">
                    <i class="bi bi-house-door"></i> หน้าแรก
                </a>
            </li>
            <li class="breadcrumb-item"><span class="text-muted">สินค้าเกษตร</span></li>
            <li class="breadcrumb-item active fw-bold text-dark" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="card product-detail-card border-0">
        <div class="row g-0">
            <!-- Image Section -->
            <div class="col-lg-5 image-section position-relative">
                <div class="text-center">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" class="img-fluid" style="object-fit: cover; width: 100%; height: 100%;" alt="@Model.Name">
                        }
                    else
                        {
                            <i class="bi bi-box-seam text-muted" style="font-size: 3rem; opacity: 0.2;"></i>
                        }
                </div>
                @if (Model.StockQuantity > 0 && Model.StockQuantity < 10)
                {
                    <div class="position-absolute top-0 start-0 m-4">
                        <span class="badge bg-warning text-dark shadow-sm px-3 py-2 rounded-pill">
                            <i class="bi bi-lightning-charge-fill"></i> สินค้าขายดี - เหลือเพียง @Model.StockQuantity ชิ้น
                        </span>
                    </div>
                }
            </div>
            
            <!-- Content Section -->
            <div class="col-lg-7">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-success-subtle text-success border border-success border-opacity-25 px-3 py-2 rounded-pill fw-bold">
                            SKU: @Model.Sku
                        </span>
                        <div class="text-muted">
                            <i class="bi bi-share cursor-pointer me-3"></i>
                            <i class="bi bi-heart cursor-pointer"></i>
                        </div>
                    </div>

                    <h1 class="display-6 fw-bold text-dark mb-3">@Model.Name</h1>
                    
                    <div class="mb-4 d-flex align-items-end gap-2">
                        <span class="price-display">฿@Model.Price.ToString("N0")</span>
                        <span class="text-muted mb-2 text-decoration-line-through">฿@((Model.Price * 1.1m).ToString("N0"))</span>
                    </div>

                    <div class="info-box mb-4 shadow-sm">
                        <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-journal-text"></i> ข้อมูลผลิตภัณฑ์</h6>
                        <p class="text-secondary lh-lg mb-0">
                            ปุ๋ยสูตรพรีเมียมจาก <strong>ชาติชายฟาร์ม</strong> ผ่านการคัดสรรส่วนผสมที่ลงตัวที่สุด 
                            เพื่อส่งเสริมการเจริญเติบโตของพืชผลในทุกช่วงวัย ช่วยปรับโครงสร้างดิน 
                            และเพิ่มความต้านทานต่อโรคพืชได้อย่างมีประสิทธิภาพ
                        </p>
                        <ul class="feature-list mt-3 small fw-semibold">
                            <li><i class="bi bi-check2-circle text-success"></i> ละลายน้ำง่าย พืชดูดซึมได้ไว</li>
                            <li><i class="bi bi-check2-circle text-success"></i> ปรับสมดุลค่า pH ในดิน</li>
                            <li><i class="bi bi-check2-circle text-success"></i> ผลิตจากวัตถุดิบคุณภาพสูง 100%</li>
                        </ul>
                    </div>

                    <div class="mb-5">
                        <h6 class="fw-bold text-muted small text-uppercase mb-3">สถานะความพร้อมของสินค้า</h6>
                        @if (Model.StockQuantity > 0)
                        {
                            <div class="stock-status bg-success-subtle text-success border border-success border-opacity-10">
                                <span class="spinner-grow spinner-grow-sm" role="status"></span>
                                มีสินค้าพร้อมจำหน่าย (คลังสินค้า: @Model.StockQuantity ชิ้น)
                            </div>
                        }
                        else
                        {
                            <div class="stock-status bg-danger-subtle text-danger border border-danger border-opacity-10">
                                <i class="bi bi-x-circle-fill"></i> ขออภัย สินค้าหมดชั่วคราว
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>