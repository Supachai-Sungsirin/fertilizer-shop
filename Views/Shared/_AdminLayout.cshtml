<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ระบบจัดการร้านขายปุ๋ย</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
            body {

                background-color: #f4f6f9;
            }

            .sidebar {
                min-height: 100vh;
                width: 260px;
                background-color: #2f3e46;
                color: white;
                position: fixed;
                display: flex;
                flex-direction: column;
            }

            .sidebar .nav-link {
                color: #cad2c5;
                padding: 12px 20px;
                margin: 4px 15px;
                border-radius: 8px;
            }

            .sidebar .nav-link:hover {
                background-color: #354f52;
                color: white;
            }

            .sidebar .nav-link.active {
                background-color: #52796f;
                color: white;
                font-weight: bold;
            }

            .content-wrapper {
                margin-left: 260px;
                padding: 30px;
                min-height: 100vh;
            }
    </style>
</head>

<body>
    <div class="d-flex">
        <nav class="sidebar py-4">
            <h4 class="text-center text-white mb-4 fw-bold">ร้านชาติชายฟาร์ม</h4>
            
            <nav class="nav flex-column flex-grow-1">
    
                @if (User.IsInRole("Owner"))
                {
                    <a href="@Url.Action("Dashboard", "Owner")"
                           class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Dashboard" ? "active" : "")">
                        <i class="bi bi-house-door me-2"></i> แดชบอร์ดเจ้าของร้าน
                    </a>
                    <a href="@Url.Action("Employees", "Owner")"
                           class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Employees" || ViewContext.RouteData.Values["Action"].ToString() == "AddEmployee" ? "active" : "")">
                        <i class="bi bi-people me-2"></i> จัดการพนักงาน
                    </a>
                }

                @if (User.IsInRole("Manager") || User.IsInRole("Owner"))
                {
                    <a href="@Url.Action("Index", "Manager")"
                           class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Manager" && ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "active" : "")">
                        <i class="bi bi-speedometer2 me-2"></i> แดชบอร์ดผู้จัดการ
                    </a>
                    <a href="@Url.Action("Products", "Owner")"
                           class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Products" ? "active" : "")">
                        <i class="bi bi-box-seam me-2"></i> จัดการข้อมูลสต็อกสินค้า
                    </a>
                    <a href="@Url.Action("Categories", "Owner")"
                           class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Categories" ? "active" : "")">
                        <i class="bi bi-tags me-2"></i> จัดการหมวดหมู่สินค้า
                    </a>
                }

                <a href="@Url.Action("Index", "Cashier")" class="nav-link" target="_blank">
                    <i class="bi bi-cart-check me-2"></i> เปิดหน้า POS
                </a>

                <hr class="text-secondary mx-3" />

                <a href="@Url.Action("Logout", "Account")" class="nav-link text-danger mt-auto">
                    <i class="bi bi-box-arrow-right me-2"></i> ออกจากระบบ
                </a>
            
            </nav>
        </nav>

        <div class="content-wrapper w-100">
            <div class="d-flex justify-content-end mb-4">
                <span class="text-muted"><i class="bi bi-person-circle"></i> สวัสดี, @User.Identity.Name</span>
            </div>

            @RenderBody()
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>